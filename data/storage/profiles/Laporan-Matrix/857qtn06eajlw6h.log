ocument.getElementById('trendChart').getContext('2d'), {\\r\\n            type: 'line',\\r\\n            data: reportData.trend,\\r\\n            options: { animation: false, scales: { y: { beginAtZero: true } } }\\r\\n        });\\r\\n\\r\\n        // 2. Render Bar Chart (Komparasi Volume/Suhu)\\r\\n        new Chart(document.getElementById('barChart').getContext('2d'), {\\r\\n            type: 'bar',\\r\\n            data: reportData.bar,\\r\\n            options: { animation: false, scales: { y: { beginAtZero: true } } }\\r\\n        });\\r\\n\\r\\n        // 3. Render Doughnut Chart (Status Sistem)\\r\\n        new Chart(document.getElementById('doughnutChart').getContext('2d'), {\\r\\n            type: 'doughnut',\\r\\n            data: reportData.doughnut,\\r\\n            options: { animation: false }\\r\\n        });\\r\\n    </script>\\r\\n</body>\\r\\n</html>\",\n+    \"helpers\": \"function JSONstringify(data) {\\r\\n    return JSON.stringify(data);\\r\\n}\",\n+    \"@odata.context\": \"http://localhost:5488/odata/$metadata#templates/$entity\",\n+    \"@odata.editLink\": \"http://localhost:5488/odata/templates('xlyBVpGxEyHceB0L')\",\n+    \"@odata.id\": \"http://localhost:5488/odata/templates('xlyBVpGxEyHceB0L')\",\n+    \"creationDate\": \"2026-04-20T09:07:29.247Z\",\n+    \"modificationDate\": \"2026-04-20T09:10:17.261Z\"\n+  },\n+  \"data\": {\n+    \"reportDate\": \"20 April 2026\",\n+    \"penjelasanTren\": \"Berdasarkan grafik di atas, Suhu Extruder (Garis Merah) mengalami kenaikan signifikan pada pukul 11:00 mencapai 75°C, namun berangsur turun. Water Treatment (Garis Teal) stabil di kisaran 40-45°C. Selisih suhu maksimal antar node adalah 30°C pada jam puncak.\",\n+    \"penjelasanBar\": \"Rata-rata akumulasi suhu/beban menunjukkan Extruder memakan daya dan menghasilkan panas 60% lebih tinggi dibandingkan sistem Water Treatment. Disarankan melakukan pengecekan sistem pendingin pada Extruder.\",\n+    \"penjelasanDoughnut\": \"Dalam 24 jam terakhir