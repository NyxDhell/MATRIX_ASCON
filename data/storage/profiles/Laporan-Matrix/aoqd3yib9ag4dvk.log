      });\r\n+    </script>\r\n+</body>\r\n+</html>\n\\ No newline at end of file\n","encoding":"diff"},"meta":{"diff":"Index: resMeta\n===================================================================\n--- resMeta\n+++ resMeta\n"}},"req":{"diff":"Index: req\n===================================================================\n--- req\n+++ req\n@@ -123,1 +123,4 @@\n-    }\n+    },\n+    \"__appDirectory\": \"D:\\\\web_plc\\\\plc-dashboard\",\n+    \"__rootDirectory\": \"D:\\\\web_plc\\\\plc-dashboard\\\\\",\n+    \"__parentModuleDirectory\": \"D:\\\\web_plc\\\\plc-dashboard\\\\node_modules\\\\@jsreport\\\\jsreport-cli\\\\lib\"\n"}}
