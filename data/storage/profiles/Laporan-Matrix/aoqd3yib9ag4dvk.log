; }\\r\\n\\r\\n        /* CONTENT STYLES */\\r\\n        .content-body { padding: 40px 50px; }\\r\\n        .section-header { border-left: 5px solid #CD3053; padding-left: 15px; margin: 30px 0 20px 0; }\\r\\n        .section-header h2 { margin: 0; color: #2A6C7A; text-transform: uppercase; font-size: 16pt; }\\r\\n        \\r\\n        .chart-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 15px; padding: 20px; margin-bottom: 20px; }\\r\\n        .insight-card { background: #eff6f7; border-left: 4px solid #2A6C7A; padding: 15px 20px; border-radius: 0 10px 10px 0; font-size: 10pt; line-height: 1.6; margin-bottom: 30px; }\\r\\n        \\r\\n        /* Grid untuk Chart Kecil */\\r\\n        .chart-grid { display: flex; gap: 20px; margin-bottom: 20px; }\\r\\n        .chart-col { flex: 1; }\\r\\n    </style>\\r\\n</head>\\r\\n<body>\\r\\n\\r\\n    <div class=\\\"cover-page\\\">\\r\\n        <div class=\\\"top-stripe\\\"></div>\\r\\n        <div class=\\\"main-content\\\">\\r\\n            <img src=\\\"https://via.placeholder.com/400x120?text=ASCON+MATRIX\\\" class=\\\"cover-logo\\\" alt=\\\"Logo\\\">\\r\\n            <h1 class=\\\"cover-title\\\">LAPORAN ANALITIK<br>SISTEM MONITORING</h1>\\r\\n            <div class=\\\"cover-divider\\\"></div>\\r\\n            <h2 class=\\\"cover-subtitle\\\">ASCON HUB | MATRIX SCALE</h2>\\r\\n        </div>\\r\\n        <div class=\\\"cover-footer\\\">\\r\\n            <div class=\\\"meta-info\\\">\\r\\n                <p>Dicetak Untuk: <strong>PT. ASCON MULTI PRATAMA</strong></p>\\r\\n                <p>Periode Data: <strong>{{reportDate}}</strong></p>\\r\\n                <p style=\\\"font-size: 9pt; color: #94a3b8; margin-top: 20px;\\\">&copy; 2026 Ascon Hub Monitoring System - Industrial Excellence</p>\\r\\n            </div>\\r\\n        </div>\\r\\n    </div>\\r\\n\\r\\n    <div class=\\\"page-break\\\"></div>\\r\\n\\r\\n    <div class=\\\"content-body\\\">\\r\\n        <div class=\\\"section-header\\\">\\r\\n 